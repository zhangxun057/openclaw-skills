"""销售信号提取脚本"""
import json, sys, requests, os
sys.stdout.reconfigure(encoding='utf-8')

def get_api_config():
    cfg_path = os.path.expanduser('~/.openclaw/openclaw.json')
    with open(cfg_path, 'r', encoding='utf-8') as f:
        cfg = json.load(f)
    ali = cfg['models']['providers']['aliyun-bailian']
    return ali['apiKey'], ali['baseUrl']

SYSTEM_PROMPT = '''【销售信号提取】
判断核心：现在或近期，有没有理由去联系对方卖酒？

强信号 = 有人生节点或明确需求，能支撑具体销售行动：
- 人生节点：婚礼、升学、开业、乔迁、周年庆、生日
- 活动预告：峰会、发布会、庆典、展会、宴请（有具体时间）
- 需求暗示：正在选伴手礼、新店筹备中、想找定制方案

不提取为信号（归入画像traits）：
- 消费实力展示（开拉菲、酒柜全是茅台）
- 饮酒偏好表达（只喝酱香）
- 一般性商务动态（无明确用酒需求）

信号提取原则：只提取强信号。强信号能支撑具体销售行动。

输出JSON数组，每条只有signals字段。无信号则signals为[]。'''

def call_api(posts, api_key, base_url):
    user_content = '\n'.join(['%d. %s|%s' % (i+1, p['nickname'], p['content'][:200]) for i, p in enumerate(posts)])
    
    url = base_url + '/chat/completions'
    resp = requests.post(url, 
        headers={'Authorization': 'Bearer ' + api_key, 'Content-Type': 'application/json'},
        json={
            'model': 'qwen3.6-plus',
            'messages': [
                {'role': 'system', 'content': SYSTEM_PROMPT},
                {'role': 'user', 'content': user_content}
            ],
            'temperature': 0.1,
            'max_tokens': 4096
        }, timeout=180)
    
    if resp.status_code != 200:
        return None
    
    content = resp.json()['choices'][0]['message']['content']
    # 去掉markdown代码块标记
    content = content.strip()
    if content.startswith('```'):
        lines = content.split('\n')
        content = '\n'.join(lines[1:-1])
    
    try:
        return json.loads(content)
    except:
        return None

def extract_signals(posts, api_key, base_url):
    """提取销售信号"""
    result = call_api(posts, api_key, base_url)
    if result is None:
        return [[]] * len(posts)
    
    signals_list = []
    for item in result:
        if item is None or not isinstance(item, dict):
            signals_list.append([])
        else:
            sg = item.get('signals', [])
            signals_list.append(sg if isinstance(sg, list) else [])
    return signals_list

if __name__ == '__main__':
    api_key, base_url = get_api_config()
    test_posts = [
        {'nickname': '杨香雪儿', 'content': '和双币基金朋友介绍项目'},
    ]
    result = extract_signals(test_posts, api_key, base_url)
    print(json.dumps(result, ensure_ascii=False))