"""内容分类提取脚本"""
import json, sys, requests, os, time
sys.stdout.reconfigure(encoding='utf-8')

def get_api_config():
    cfg_path = os.path.expanduser('~/.openclaw/openclaw.json')
    with open(cfg_path, 'r', encoding='utf-8') as f:
        cfg = json.load(f)
    ali = cfg['models']['providers']['aliyun-bailian']
    return ali['apiKey'], ali['baseUrl']

SYSTEM_PROMPT = '''【内容分类】
从内容表达性质判断分类：

- 动态分享：发布自己的活动、行程、工作进展、生活动态
- 观点输出：发表看法、感悟、行业观点、人生思考
- 内容转发：转文章/海报/新闻/视频
- 展示分享：展示消费场景、产品、成果、生活片段
- 广告推广：产品推广、品牌宣传、活动招商

只输出分类名称，不要解释。

异常处理规则：
- 内容无法归类：填"未知"
- 纯表情/纯链接：填"内容转发"
- 内容模糊不确定：填"未知"

输出JSON数组，每条只有post_type字段。'''

def call_api(posts, api_key, base_url, model='qwen3.6-plus'):
    user_content = '\n'.join(['%d. %s|%s' % (i+1, p['nickname'], p['content'][:200]) for i, p in enumerate(posts)])
    
    url = base_url + '/chat/completions'
    resp = requests.post(url, 
        headers={'Authorization': 'Bearer ' + api_key, 'Content-Type': 'application/json'},
        json={
            'model': model,
            'messages': [
                {'role': 'system', 'content': SYSTEM_PROMPT},
                {'role': 'user', 'content': user_content}
            ],
            'temperature': 0.1,
            'max_tokens': 4096
        }, timeout=180)
    
    if resp.status_code != 200:
        raise Exception(f"API error: {resp.status_code} {resp.text[:200]}")
    
    content = resp.json()['choices'][0]['message']['content']
    content = content.strip()
    if content.startswith('```'):
        lines = content.split('\n')
        content = '\n'.join(lines[1:-1])
    
    return json.loads(content)

def call_with_retry(posts, api_key, base_url, model, max_retries=2):
    last_error = None
    for attempt in range(max_retries + 1):
        try:
            return call_api(posts, api_key, base_url, model)
        except Exception as e:
            last_error = e
            if attempt < max_retries:
                wait = 5 * (3 ** attempt)
                print(f"    API调用失败，{wait}秒后重试 ({attempt+1}/{max_retries}): {str(e)[:80]}")
                time.sleep(wait)
    return None

def extract_post_type(posts, api_key, base_url, fallback_configs=None):
    """提取内容分类"""
    result = None
    result = call_with_retry(posts, api_key, base_url, 'qwen3.6-plus')
    
    if result is None and fallback_configs:
        for fb in fallback_configs:
            try:
                print(f"    切换到备选模型: {fb.get('model', 'unknown')}")
                result = call_with_retry(posts, fb['apiKey'], fb['baseUrl'], fb.get('model', 'qwen3.5-plus'), max_retries=1)
                if result is not None:
                    break
            except:
                continue
    
    if result is None:
        return [None] * len(posts)
    
    type_list = []
    for item in result:
        if item is None or not isinstance(item, dict):
            type_list.append(None)
        else:
            tp = item.get('post_type', None)
            type_list.append(tp if tp else None)
    return type_list

if __name__ == '__main__':
    api_key, base_url = get_api_config()
    test_posts = [
        {'nickname': '杨香雪儿', 'content': '和双币基金朋友介绍项目'},
    ]
    result = extract_post_type(test_posts, api_key, base_url)
    print(json.dumps(result, ensure_ascii=False))
